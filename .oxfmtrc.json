{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "trailingComma": "es5",
  "importOrder": ["<THIRD_PARTY_MODULES>", "", "^[.]"],
  "importOrderTypeScriptVersion": "5.0.0",
  "importOrderCaseSensitive": true,
  "sortPackageJson": {
    "sortScripts": false
  },
  "ignorePatterns": [
    "CHANGELOG.md",
    "**/*/CHANGELOG.md",
    ".github/*",
    "**/*.hbs",
    "**/*/report.md",
    "clients/**/src",
    "clients/**/README.md",
    "clients/**/test/index-objects.spec.mjs",
    "clients/**/test/index-types.ts",
    "clients/**/test/snapshots.integ.spec.ts",
    "private/**",
    "!private/aws-client-api-test/src/**/*",
    "packages-internal/nested-clients/src/submodules/**/*.ts",
    "packages-internal/nested-clients/src/",
    "lib/lib-dynamodb/src/DynamoDBDocument.ts",
    "lib/lib-dynamodb/src/DynamoDBDocumentClient.ts",
    "lib/lib-dynamodb/src/index.ts",
    "lib/lib-dynamodb/src/commands/*Command.ts",
    "lib/lib-dynamodb/src/commands/index.ts",
    "lib/lib-dynamodb/src/pagination/",
    "packages-internal/core/src/submodules/client/util-endpoints/lib/aws/partitions.ts",
    "packages-internal/util-endpoints/src/lib/aws/partitions.json",
    "codegen/smithy-aws-typescript-codegen/src/main/resources/software/amazon/smithy/aws/typescript/codegen/sdk-default-configuration.json",
    "codegen/smithy-aws-typescript-codegen/src/main/resources/software/amazon/smithy/aws/typescript/codegen/endpoints.json",
    "codegen/sdk-codegen/aws-models/",
    "reserved/**",
    "**/dist/*",
    "**/dist-types/*",
    "**/dist-es/*",
    "**/dist-cjs/*"
  ]
}
