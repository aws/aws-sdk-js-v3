        "smithy.api#documentation": "<p>Returns the current account customization settings, including account color, visible services, and visible Regions. Settings that you have not configured return their default values: visible Regions and visible services return `null`, and account color returns `none`.</p> <note> <p>The <code>visibleServices</code> and <code>visibleRegions</code> settings control only the appearance of services and Regions in the Amazon Web Services Management Console. They do not restrict access through the CLI, SDKs, or other APIs.</p> </note>",
        "smithy.api#examples": [
          {
            "title": "Get account customizations",
            "documentation": "Retrieves all account customization settings",
            "input": {},
            "output": {
              "accountColor": "green",
              "visibleServices": ["s3", "ec2"],
              "visibleRegions": ["us-east-1", "us-west-2"]
            }
          }
        ],
