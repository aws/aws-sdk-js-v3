{
  "name": "@aws-sdk/middleware-sdk-s3",
  "version": "3.972.65",
  "homepage": "https://github.com/aws/aws-sdk-js-v3/tree/main/packages-internal/middleware-sdk-s3",
  "license": "Apache-2.0",
  "author": {
    "name": "AWS SDK for JavaScript Team",
    "url": "https://aws.amazon.com/sdk-for-javascript/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aws/aws-sdk-js-v3.git",
    "directory": "packages-internal/middleware-sdk-s3"
  },
  "files": [
    "./s3-control.d.ts",
    "./s3-control.js",
    "./s3.d.ts",
    "./s3.js",
    "dist-*/**"
  ],
  "sideEffects": false,
  "main": "./dist-cjs/index.js",
  "module": "./dist-es/index.js",
  "browser": {
    "./dist-es/submodules/s3/index": "./dist-es/submodules/s3/index.browser",
    "./dist-es/submodules/s3/index.js": "./dist-es/submodules/s3/index.browser.js",
    "./dist-es/submodules/s3/to-stream/toStream": "./dist-es/submodules/s3/to-stream/toStream.browser"
  },
  "types": "./dist-types/index.d.ts",
  "typesVersions": {
    "<4.5": {
      "dist-types/*": [
        "dist-types/ts3.4/*"
      ],
      "*": [
        "dist-types/ts3.4/submodules/*/index.d.ts"
      ]
    }
  },
  "react-native": {
    "./dist-es/submodules/s3/index": "./dist-es/submodules/s3/index.browser",
    "./dist-es/submodules/s3/to-stream/toStream": "./dist-es/submodules/s3/to-stream/toStream.browser",
    "./dist-es/submodules/s3/index.js": "./dist-es/submodules/s3/index.browser.js"
  },
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "module": "./dist-es/index.js",
      "node": "./dist-cjs/index.js",
      "import": "./dist-es/index.js",
      "require": "./dist-cjs/index.js"
    },
    "./package.json": {
      "module": "./package.json",
      "node": "./package.json",
      "import": "./package.json",
      "require": "./package.json"
    },
    "./s3": {
      "types": "./dist-types/submodules/s3/index.d.ts",
      "react-native": "./dist-es/submodules/s3/index.browser.js",
      "browser": "./dist-es/submodules/s3/index.browser.js",
      "module": "./dist-es/submodules/s3/index.js",
      "node": "./dist-cjs/submodules/s3/index.js",
      "import": "./dist-es/submodules/s3/index.js",
      "require": "./dist-cjs/submodules/s3/index.js"
    },
    "./s3-control": {
      "types": "./dist-types/submodules/s3-control/index.d.ts",
      "module": "./dist-es/submodules/s3-control/index.js",
      "node": "./dist-cjs/submodules/s3-control/index.js",
      "import": "./dist-es/submodules/s3-control/index.js",
      "require": "./dist-cjs/submodules/s3-control/index.js"
    }
  },
  "scripts": {
    "build": "concurrently 'yarn:build:types' 'yarn:build:es' && yarn build:cjs",
    "build:cjs": "node ../../scripts/compilation/inline",
    "build:es": "premove dist-es && tsc -p tsconfig.es.json",
    "build:include:deps": "yarn g:turbo run build -F=\"$npm_package_name\"",
    "build:types": "premove dist-types && tsc -p tsconfig.types.json",
    "build:types:downlevel": "downlevel-dts dist-types dist-types/ts3.4",
    "clean": "premove dist-cjs dist-es dist-types",
    "extract:docs": "api-extractor run --local",
    "lint": "node ../../scripts/validation/submodules-linter.js",
    "prebuild": "yarn lint",
    "test": "yarn g:vitest run",
    "test:watch": "yarn g:vitest watch",
    "test:integration": "yarn g:vitest run -c vitest.config.integ.mts && yarn test:types",
    "test:integration:watch": "yarn test:types && yarn g:vitest watch -c vitest.config.integ.mts",
    "test:e2e": "yarn g:vitest run -c vitest.config.e2e.mts --mode development",
    "test:e2e:watch": "yarn g:vitest watch -c vitest.config.e2e.mts --mode development",
    "test:types": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@aws-sdk/core": "workspace:^3.976.0",
    "@aws-sdk/signature-v4-multi-region": "workspace:^3.996.41",
    "@aws-sdk/types": "workspace:^3.974.2",
    "@smithy/core": "^3.29.8",
    "@smithy/types": "^4.16.1",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@tsconfig/recommended": "1.0.1",
    "concurrently": "7.0.0",
    "downlevel-dts": "0.10.1",
    "premove": "4.0.0",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
