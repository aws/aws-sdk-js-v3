{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist-cjs",
    "rootDir": "src",
    "noCheck": true,
    "paths": {
      "@aws-sdk/checksums/crc32c": ["./src/submodules/crc32c/index.ts"],
      "@aws-sdk/checksums/crc64-nvme": ["./src/submodules/crc64-nvme/index.ts"],
      "@aws-sdk/checksums/flexible-checksums": ["./src/submodules/flexible-checksums/index.ts"],
      "@aws-sdk/checksums/crc": ["./src/submodules/crc/index.ts"],
      "@aws-sdk/checksums/sha": ["./src/submodules/sha/index.ts"],
      "@aws-sdk/checksums/md5": ["./src/submodules/md5/index.ts"]
    }
  },
  "extends": "../../tsconfig.cjs.json",
  "include": ["src/"]
}
