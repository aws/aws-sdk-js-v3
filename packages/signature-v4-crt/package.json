{
  "name": "@aws-sdk/signature-v4-crt",
  "version": "3.1088.0",
  "description": "A revision of AWS Signature V4 request signer based on AWS Common Runtime https://github.com/awslabs/aws-crt-nodejs",
  "homepage": "https://github.com/aws/aws-sdk-js-v3/tree/main/packages/signature-v4-crt",
  "license": "Apache-2.0",
  "author": {
    "name": "AWS SDK for JavaScript Team",
    "url": "https://aws.amazon.com/sdk-for-javascript/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aws/aws-sdk-js-v3.git",
    "directory": "packages/signature-v4-crt"
  },
  "files": [
    "dist-*/**"
  ],
  "sideEffects": true,
  "main": "./dist-cjs/index.js",
  "module": "./dist-es/index.js",
  "types": "./dist-types/index.d.ts",
  "scripts": {
    "build": "concurrently 'yarn:build:types' 'yarn:build:es' && yarn build:cjs",
    "build:cjs": "node ../../scripts/compilation/inline",
    "build:es": "premove dist-es && tsc -p tsconfig.es.json",
    "build:include:deps": "yarn g:turbo run build -F=\"$npm_package_name\"",
    "build:types": "premove dist-types && tsc -p tsconfig.types.json",
    "build:types:downlevel": "downlevel-dts dist-types dist-types/ts3.4",
    "clean": "premove dist-cjs dist-es dist-types",
    "extract:docs": "api-extractor run --local",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/crt-loader": "workspace:^3.972.63",
    "@aws-sdk/signature-v4-multi-region": "workspace:^3.996.41",
    "@aws-sdk/types": "workspace:^3.974.2",
    "@smithy/core": "^3.29.4",
    "@smithy/signature-v4": "^5.6.5",
    "@smithy/types": "^4.16.1",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@tsconfig/recommended": "1.0.1",
    "concurrently": "7.0.0",
    "downlevel-dts": "0.10.1",
    "jest": "^30.2.0",
    "premove": "4.0.0",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
